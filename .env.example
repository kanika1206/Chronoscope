# =============================================================================
# Chronoscope — Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env            (Ubuntu/macOS)
#     copy .env.example .env          (Windows CMD)
#
# EVERY variable below has a sensible default baked into the code, so `.env`
# is OPTIONAL for local development (defaults target localhost infra started
# by docker-compose). Set values here only to override.
#
# When running inside Docker Compose, the compose file injects the correct
# hostnames (kafka, postgres, redis) automatically — you do NOT need a .env
# for the containerized path.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development           # development | production
LOG_LEVEL=info                 # error | warn | info | debug

# ---------------------------------------------------------------------------
# Kafka (event streaming backbone)
# ---------------------------------------------------------------------------
# Host dev:            localhost:9092
# Inside Docker net:   kafka:29092
KAFKA_BROKER=localhost:9092

# ---------------------------------------------------------------------------
# PostgreSQL (event store)
# ---------------------------------------------------------------------------
DB_HOST=localhost              # "postgres" inside Docker network
DB_PORT=5432
DB_NAME=chronoscope
DB_USER=replay_user
DB_PASSWORD=replay_pass        # CHANGE for any non-local deployment
DB_POOL_MAX=20                 # max PG connections per service pool

# ---------------------------------------------------------------------------
# Redis (idempotency cache — used by replay-engine)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost           # "redis" inside Docker network
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Service ports (each microservice binds its own HTTP port)
# ---------------------------------------------------------------------------
ORDER_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
INGESTOR_PORT=3003
REPLAY_ENGINE_PORT=3004
DEBUG_API_PORT=3005            # also serves the frontend UI

# ---------------------------------------------------------------------------
# Cross-service URLs
# ---------------------------------------------------------------------------
# Debug API calls the Replay Engine over HTTP.
# Host dev:          http://localhost:3004
# Inside Docker net: http://replay-engine:3004
REPLAY_ENGINE_URL=http://localhost:3004

# ---------------------------------------------------------------------------
# Replay Engine behavior
# ---------------------------------------------------------------------------
# dry-run       → simulate replay, no state changes / side effects
# state-rebuild → rebuild state from event history
REPLAY_MODE=dry-run
